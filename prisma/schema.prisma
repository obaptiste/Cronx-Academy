generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PARENT
  LEARNER
  TUTOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  progress    Progress[]
  quizResults QuizResult[]

  @@map("users")
}

enum ModuleStatus {
  READY
  COMING_SOON
}

model Module {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  icon        String
  description String
  colorClass  String
  href        String
  status      ModuleStatus @default(READY)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  lessons Lesson[]

  @@map("modules")
}

enum LessonType {
  HISTORY
  MATH
  CHEMISTRY
  GENERAL
}

model Lesson {
  id         String     @id @default(cuid())
  moduleId   String
  title      String
  topic      String
  lessonType LessonType @default(HISTORY)
  sortOrder  Int        @default(0)
  data       Json
  createdAt  DateTime   @default(now())

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    Progress[]
  quizResults QuizResult[]

  @@unique([moduleId, title])
  @@index([moduleId, topic])
  @@map("lessons")
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("progress")
}

model QuizResult {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  score          Int
  totalQuestions Int
  completedAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@map("quiz_results")
}

enum FaultSeverity {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  BOOLEAN
  INFO
}

model Fault {
  id                  String        @id @default(cuid())
  slug                String        @unique
  title               String
  summary             String
  description         String
  severity            FaultSeverity
  dangerNotes         String
  likelyCauses        Json
  safeChecks          Json
  electricianTestsNext Json
  tags                String[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  symptoms Symptom[]
}

model Symptom {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String
  faultId     String?

  fault Fault? @relation(fields: [faultId], references: [id], onDelete: SetNull)
}

model DecisionTree {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  symptomSlug String
  startNodeId String

  nodes DecisionNode[]
}

model DecisionNode {
  id                String       @id @default(cuid())
  treeId            String
  key               String
  question          String
  explanation       String
  questionType      QuestionType
  severity          FaultSeverity
  safetyGate        Boolean      @default(false)
  stopReason        String?
  educationalNote   String?
  recommendedAction String?

  tree    DecisionTree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  options DecisionOption[]

  @@unique([treeId, key])
}

model DecisionOption {
  id                     String  @id @default(cuid())
  nodeId                 String
  label                  String
  value                  String
  nextNodeKey            String?
  scoreModifier          Int     @default(0)
  faultWeightAdjustments Json?

  node DecisionNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model DiagnosisSession {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  symptomSlug    String
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  resultFaultSlug String?
  riskLevel      String?

  answers DiagnosisAnswer[]
}

model DiagnosisAnswer {
  id                 String @id @default(cuid())
  diagnosisSessionId String
  nodeKey            String
  answerValue        String

  diagnosisSession DiagnosisSession @relation(fields: [diagnosisSessionId], references: [id], onDelete: Cascade)
}

model LearningArticle {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  body              String
  relatedFaultSlugs String[]
}
